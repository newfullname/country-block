#!/usr/bin/env bash
set -euo pipefail

# Define colors for log output
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

readonly CONFIG_FILE="/etc/country-block/config.conf"
readonly CACHE_DIR="/var/cache/country-block"
readonly IPSET_SAVE_FILE="${CACHE_DIR}/ipsets.save"
readonly IPSET_PREFIX="country_"
readonly IP_SOURCE_URL="https://www.ipdeny.com/ipblocks/data/countries"
readonly IP6_SOURCE_URL="https://www.ipdeny.com/ipv6/ipaddresses/blocks"
readonly MAX_FILE_AGE_DAYS=7
readonly LOCK_FILE="/var/lock/country-block.lock"

# Function to log messages
log() {
	echo -e "[ ${BLUE}country-block-update${NC} ] $1"
	logger -t country-block-update "$1"
}

sanitize_config_line() {
  local line="$1"
  line="${line%%#*}"
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"
  printf '%s' "$line"
}

parse_config_entry() {
	local line="$1"
	read -r countries chains ip_versions <<< "$line"
	if [[ -z "${countries}" ]] || [[ -z "${chains}" ]]; then
		log "WARNING: Invalid config entry '${line}'. Missing fields."
		return 1
	fi
	countries="${countries,,}"
	chains="${chains,,}"
	ip_versions="${ip_versions:-*}"
	ip_versions="${ip_versions,,}"

	declare -a valid_countries=()
	IFS=',' read -ra country_array <<< "${countries}"
	for c in "${country_array[@]}"; do
		c="${c// /}"
		[[ -z "${c}" ]] && continue
		if [[ ! "${c}" =~ ^[a-z]{2}$ ]]; then
			log "WARNING: Invalid country code '${c}' in config entry '${line}'."
			continue
		fi
		valid_countries+=("${c}")
	done
	if [[ ${#valid_countries[@]} -eq 0 ]]; then
		log "WARNING: No valid country codes in config entry '${line}'."
		return 1
	fi

	declare -a valid_chains=()
	if [[ "${chains}" == "*" ]]; then
		valid_chains=("input" "output" "forward")
	else
		IFS=',' read -ra chain_array <<< "${chains}"
		for ch in "${chain_array[@]}"; do
			ch="${ch// /}"
			[[ -z "${ch}" ]] && continue
			case "${ch}" in
				input|output|forward) valid_chains+=("${ch}") ;;
				*) log "WARNING: Invalid chain '${ch}' in config entry '${line}'." ;;
			esac
		done
	fi
	if [[ ${#valid_chains[@]} -eq 0 ]]; then
		log "WARNING: No valid chains in config entry '${line}'."
		return 1
	fi

	declare -a valid_ip_versions=()
	if [[ "${ip_versions}" == "*" ]]; then
		valid_ip_versions=("v4" "v6")
	else
		IFS=',' read -ra ip_array <<< "${ip_versions}"
		for ip in "${ip_array[@]}"; do
			ip="${ip// /}"
			[[ -z "${ip}" ]] && continue
			case "${ip}" in
				v4|v6) valid_ip_versions+=("${ip}") ;;
				*) log "WARNING: Invalid IP version '${ip}' in config entry '${line}'." ;;
			esac
		done
	fi
	if [[ ${#valid_ip_versions[@]} -eq 0 ]]; then
		log "WARNING: No valid IP versions in config entry '${line}'."
		return 1
	fi

	entry_countries="${valid_countries[*]}"
	entry_chains="${valid_chains[*]}"
	entry_ip_versions="${valid_ip_versions[*]}"
	return 0
}

acquire_lock() {
  mkdir -p "$(dirname "${LOCK_FILE}")"
  exec 200>"${LOCK_FILE}"
  if ! flock -n 200; then
    log "ERROR: Another country-block operation is running."
    exit 1
  fi
}

# --- Main Execution ---

# Determine the directory of the currently executing script
readonly SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

if [[ "${EUID}" -ne 0 ]]; then
  log "ERROR: This script must be run as root."
  exit 1
fi

acquire_lock

log "Starting update of country block lists..."
mkdir -p "${CACHE_DIR}"

if [[ ! -f "${CONFIG_FILE}" ]]; then
  log "ERROR: Configuration file not found at ${CONFIG_FILE}"
  exit 1
fi

log "Handing off to country-block-apply to sync iptables before cleanup."
COUNTRY_BLOCK_SKIP_LOCK=1 "${SCRIPT_DIR}/country-block-apply"

# --- Cleanup Phase ---
declare -a config_lines
while IFS= read -r raw_line || [[ -n "${raw_line}" ]]; do
  sanitized_line="$(sanitize_config_line "${raw_line}")"
  if [[ -n "${sanitized_line}" ]]; then
    config_lines+=("${sanitized_line}")
  fi
done < "${CONFIG_FILE}"

declare -A required_countries
for line in "${config_lines[@]}"; do
	if ! parse_config_entry "${line}"; then
		continue
	fi
	for country in ${entry_countries}; do
		required_countries["${country}"]=1
	done
done

log "Checking for obsolete ipsets to remove..."
if [[ -f "${IPSET_SAVE_FILE}" ]]; then
  ipset restore -exist < "${IPSET_SAVE_FILE}" || true # Continue if restore fails, as sets might not exist
fi

# Get all existing ipsets managed by this script
all_managed_ipsets=$(ipset list -n | grep "^${IPSET_PREFIX}" || true)

for ipset_name in ${all_managed_ipsets}; do
  # Extract country code and IP version from the ipset name
  # Assuming format: country_CC_v4 or country_CC_v6
  if [[ "${ipset_name}" =~ ^${IPSET_PREFIX}([A-Za-z]{2})_(v[46])$ ]]; then
    country_code="${BASH_REMATCH[1]}"
    ip_version="${BASH_REMATCH[2]}"

    country_code="${country_code,,}"

    if [[ ! -v required_countries["${country_code}"] ]]; then
      log "Country '${country_code}' no longer in config. Removing its ${ip_version} ipset and cache."
      ipset destroy "${ipset_name}" || true # Destroy might fail if set is already gone
      rm -f "${CACHE_DIR}/${country_code}.zone.${ip_version}"
    fi
  else
    log "WARNING: Found an ipset '${ipset_name}' with an unexpected naming convention. Skipping cleanup."
  fi
done

log "Processing countries from config file..."
for line in "${config_lines[@]}"; do
	if ! parse_config_entry "${line}"; then
		continue
	fi

	for country in ${entry_countries}; do
		for ip_version in ${entry_ip_versions}; do
			if [[ "${ip_version}" == "v4" ]]; then
				ip_list_file="${CACHE_DIR}/${country}.zone.v4"
				ipset_name="${IPSET_PREFIX}${country}_v4"
				should_download=false

				if [[ ! -f "${ip_list_file}" ]]; then
					log "IPv4 list for '${country}' not found. Scheduling download."
					should_download=true
				else
					file_age_days=$(( ($(date +%s) - $(date +%s -r "${ip_list_file}")) / 86400 ))
					if [[ "${file_age_days}" -ge "${MAX_FILE_AGE_DAYS}" ]]; then
						log "IPv4 list for '${country}' is old. Scheduling re-download."
						should_download=true
					fi
				fi

				if [[ "${should_download}" == true ]]; then
					log "Downloading IPv4 list for ${country}..."
					if ! curl -fsSL --compressed "${IP_SOURCE_URL}/${country}.zone" -o "${ip_list_file}"; then
						log "ERROR: Failed to download IPv4 list for ${country}."
						if [[ ! -s "${ip_list_file}" ]]; then
							log "WARNING: Skipping IPv4 update for ${country} due to download failure."
						fi
					fi
				fi

				if [[ -s "${ip_list_file}" ]]; then
					log "Updating ipset: ${ipset_name}"
					tmp_ipset_name="${ipset_name}_tmp"

					ipset create "${tmp_ipset_name}" hash:net family inet -exist
					ipset flush "${tmp_ipset_name}"
					while read -r cidr; do
						ipset add "${tmp_ipset_name}" "${cidr}" -exist
					done < "${ip_list_file}"

					if ipset list "${ipset_name}" &>/dev/null; then
						ipset swap "${tmp_ipset_name}" "${ipset_name}"
						ipset destroy "${tmp_ipset_name}"
					else
						ipset rename "${tmp_ipset_name}" "${ipset_name}"
					fi
				fi
			elif [[ "${ip_version}" == "v6" ]]; then
				ip_list_file="${CACHE_DIR}/${country}.zone.v6"
				ipset_name="${IPSET_PREFIX}${country}_v6"
				should_download=false

				if [[ ! -f "${ip_list_file}" ]]; then
					log "IPv6 list for '${country}' not found. Scheduling download."
					should_download=true
				else
					file_age_days=$(( ($(date +%s) - $(date +%s -r "${ip_list_file}")) / 86400 ))
					if [[ "${file_age_days}" -ge "${MAX_FILE_AGE_DAYS}" ]]; then
						log "IPv6 list for '${country}' is old. Scheduling re-download."
						should_download=true
					fi
				fi

				if [[ "${should_download}" == true ]]; then
					log "Downloading IPv6 list for ${country}..."
					if ! curl -fsSL --compressed "${IP6_SOURCE_URL}/${country}.zone" -o "${ip_list_file}"; then
						log "ERROR: Failed to download IPv6 list for ${country}."
						if [[ ! -s "${ip_list_file}" ]]; then
							log "WARNING: Skipping IPv6 update for ${country} due to download failure."
						fi
					fi
				fi

				if [[ -s "${ip_list_file}" ]]; then
					log "Updating ipset: ${ipset_name}"
					tmp_ipset_name="${ipset_name}_tmp"

					ipset create "${tmp_ipset_name}" hash:net family inet6 -exist
					ipset flush "${tmp_ipset_name}"
					while read -r cidr; do
						ipset add "${tmp_ipset_name}" "${cidr}" -exist
					done < "${ip_list_file}"

					if ipset list "${ipset_name}" &>/dev/null; then
						ipset swap "${tmp_ipset_name}" "${ipset_name}"
						ipset destroy "${tmp_ipset_name}"
					else
						ipset rename "${tmp_ipset_name}" "${ipset_name}"
					fi
				fi
			fi
		done
	done
done

# --- Save State for Persistence ---
log "Saving current ipset state for persistence..."
if ! ipset save > "${IPSET_SAVE_FILE}"; then
    log "ERROR: Failed to save ipset state. Rules may not persist after reboot."
    exit 1
fi
log "ipset state saved successfully to ${IPSET_SAVE_FILE}"

# --- Apply Rules ---
log "Handing off to country-block-apply to sync iptables."
COUNTRY_BLOCK_SKIP_LOCK=1 "${SCRIPT_DIR}/country-block-apply"

log "Update script finished."
exit 0
